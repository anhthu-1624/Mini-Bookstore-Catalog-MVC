@model List<AspNetWeek4.Mvc.ViewModels.SaleHistoryViewModel>
@{ ViewData["Title"] = "Lịch sử bán hàng"; }

<h2>Lịch sử bán hàng</h2>
<p class="text-muted">Tổng <strong>@Model.Count</strong> giao dịch</p>

@foreach (var sale in Model)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between">
            <span><strong>#@sale.Id</strong> — @sale.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            <span class="text-primary fw-bold">@sale.TotalAmount.ToString("N0") VNĐ</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã sách</th>
                        <th>Tên sách</th>
                        <th>SL</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in sale.Items)
                    {
                        <tr>
                            <td><code>@item.BookCode</code></td>
                            <td>@item.BookTitle</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                            <td>@item.Subtotal.ToString("N0") VNĐ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}