@model PagedResult<BookListItemViewModel>
@{
    ViewData["Title"] = "Danh Sách Sách";

    string keyword = ViewBag.Keyword ?? "";
    string genre   = ViewBag.Genre   ?? "";
    string stock   = ViewBag.Stock   ?? "";
    string sortBy  = ViewBag.SortBy  ?? "title";
    var    genres  = (List<string>)(ViewBag.Genres ?? new List<string>());

    var prevDisabled = !Model.HasPrevPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<div class="page-header">
    <div>
        <h2 class="page-title">📚 Danh Sách Sách</h2>
        <p class="page-description">
            Toàn bộ sách hiện có trong kho — tìm kiếm, lọc và sắp xếp nhanh chóng.
        </p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-success" asp-controller="Books" asp-action="Create">+ Thêm sách</a>
        <a class="btn btn-primary" asp-controller="Books" asp-action="Stats">📊 Thống kê</a>
    </div>
</div>

<form method="get" asp-controller="Books" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="keyword" value="@keyword"
               class="form-control" placeholder="🔍 Tìm theo tên, tác giả, ISBN..." />
    </div>
    <div class="col-md-2">
        <select name="genre" class="form-select">
            <option value="">-- Thể loại --</option>
            @foreach (var g in genres)
            {
                if (genre == g)
                {
                    <option value="@g" selected>@g</option>
                }
                else
                {
                    <option value="@g">@g</option>
                }
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="stock" class="form-select">
            <option value="">-- Tồn kho --</option>
            @if (stock == "ok") { <option value="ok" selected>Còn sách</option> }
            else { <option value="ok">Còn sách</option> }
            @if (stock == "low") { <option value="low" selected>Sắp hết</option> }
            else { <option value="low">Sắp hết</option> }
            @if (stock == "out") { <option value="out" selected>Hết sách</option> }
            else { <option value="out">Hết sách</option> }
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortBy" class="form-select">
            @if (sortBy == "title") { <option value="title" selected>Tên A→Z</option> }
            else { <option value="title">Tên A→Z</option> }
            @if (sortBy == "author") { <option value="author" selected>Tác giả A→Z</option> }
            else { <option value="author">Tác giả A→Z</option> }
            @if (sortBy == "price") { <option value="price" selected>Giá tăng dần</option> }
            else { <option value="price">Giá tăng dần</option> }
            @if (sortBy == "price_desc") { <option value="price_desc" selected>Giá giảm dần</option> }
            else { <option value="price_desc">Giá giảm dần</option> }
            @if (sortBy == "stock") { <option value="stock" selected>Tồn kho tăng</option> }
            else { <option value="stock">Tồn kho tăng</option> }
            @if (sortBy == "newest") { <option value="newest" selected>Mới nhất</option> }
            else { <option value="newest">Mới nhất</option> }
        </select>
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100">Lọc</button>
    </div>
    <div class="col-md-1">
        <a asp-controller="Books" asp-action="Index" class="btn btn-outline-secondary w-100">Xoá</a>
    </div>
</form>

<div class="info-panel mb-3">
    <strong>Tìm thấy:</strong> @Model.TotalItems cuốn
    — Trang <strong>@Model.Page</strong> / @Model.TotalPages
</div>

@if (Model.TotalItems == 0)
{
    <div class="alert alert-warning">
        Không tìm thấy sách nào phù hợp.
        <a asp-controller="Books" asp-action="Index">Xem tất cả</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                @await Html.PartialAsync("_BookCard", item)
            </div>
        }
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @prevDisabled">
                <a class="page-link"
                   asp-controller="Books" asp-action="Index"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-keyword="@keyword"
                   asp-route-genre="@genre"
                   asp-route-stock="@stock"
                   asp-route-sortBy="@sortBy">
                    ‹ Trước
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                var activeClass = (i == Model.Page) ? "active" : "";
                <li class="page-item @activeClass">
                    <a class="page-link"
                       asp-controller="Books" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-keyword="@keyword"
                       asp-route-genre="@genre"
                       asp-route-stock="@stock"
                       asp-route-sortBy="@sortBy">
                        @i
                    </a>
                </li>
            }
            <li class="page-item @nextDisabled">
                <a class="page-link"
                   asp-controller="Books" asp-action="Index"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-keyword="@keyword"
                   asp-route-genre="@genre"
                   asp-route-stock="@stock"
                   asp-route-sortBy="@sortBy">
                    Sau ›
                </a>
            </li>
        </ul>
    </nav>
}

<p class="mt-4">
    <a class="btn btn-light" asp-controller="Home" asp-action="Index">← Quay lại trang chủ</a>
</p>
